modules = ["nodejs-20", "web"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-25_05"
packages = ["wmutils-core", "tree", "openssh_gssapi", "doppler", "jq"]

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 24678
externalPort = 3001

[[ports]]
localPort = 39537
externalPort = 3000

[env]
PORT = "5000"

[workflows]
runButton = "Start application with Doppler"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start application with Doppler"
author = 49920518
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "doppler run -- npm run dev"

[agent]
integrations = ["javascript_database:1.0.0", "github:1.0.0", "resend:1.0.0", "notion:1.0.0", "twilio:1.0.0", "javascript_log_in_with_replit:1.0.0"]
expertMode = true
